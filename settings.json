{
  // Caps as second escape
  "keyboard.dispatch": "keyCode",

  // Editor
  "editor.lineNumbers": "relative",
  "editor.fontFamily": "'JetBrains Mono', 'monospace', monospace",
  "editor.fontSize": 16,
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.inlineSuggest.enabled": true,

  // Workbench
  "workbench.colorTheme": "Everforest Dark",
  "workbench.iconTheme": "material-icon-theme",

  // Explorer
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,

  // Vscode neovim
  "vscode-neovim.mouseSelectionStartVisualMode": true,
  "vscode-neovim.useCtrlKeysForInsertMode": false,
  "vscode-neovim.useCtrlKeysForNormalMode": false,
  "extensions.experimental.affinity": {
    "asvetliakov.vscode-neovim": 1
  },

  // File associations
  "files.associations": {
    "*.yml": "ansible"
  },

  // Python
  "python.formatting.provider": "yapf",
  "[python]": {
    "editor.codeActionsOnSave": {
      "soirce.organizeImports": true
    },
    "editor.formatOnType": true,
    "editor.defaultFormatter": "ms-python.python"
  },
  "isort.showNotifications": "always",
  "isort.check": true,

  // Misc
  "redhat.telemetry.enabled": false,
  "security.workspace.trust.untrustedFiles": "open",
  "yaml.customTags": [
    "!And",
    "!And sequence",
    "!If",
    "!If sequence",
    "!Not",
    "!Not sequence",
    "!Equals",
    "!Equals sequence",
    "!Or",
    "!Or sequence",
    "!FindInMap",
    "!FindInMap sequence",
    "!Base64",
    "!Join",
    "!Join sequence",
    "!Cidr",
    "!Ref",
    "!Sub",
    "!Sub sequence",
    "!GetAtt",
    "!GetAZs",
    "!ImportValue",
    "!ImportValue sequence",
    "!Select",
    "!Select sequence",
    "!Split",
    "!Split sequence"
  ],

  // Copilot
  "github.copilot.enable": {
    "*": true,
    "yaml": false,
    "plaintext": false,
    "markdown": true,
    "scminput": false
  },

  // Ansible
  "ansible.python.interpreterPath": "/home/forest23/src/ansible-venvs/2.12.5/bin/python",
  "pylint.importStrategy": "fromEnvironment"
}
